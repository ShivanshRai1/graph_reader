    {
      "tableTitle": "Electrical Characteristics Notes",
      "columns": [
        "Note",
        "Text"
      ],
      "rows": [
        {
          "Note": "1",
          "Text": "The LT7153SP is tested under pulsed load conditions such that TJ ≈ TA. Specifications over the –40°C to 125°C operating junction temperature range are assured by design, characterization, and correlation with statistical process controls. The LT7153SP is guaranteed over the full –40°C to 125°C operating junction temperature range. Note that the maximum ambient temperature consistent with these specifications is determined by specific operating conditions in conjunction with board layout, the rated package thermal impedance, and other environmental factors. The junction temperature (TJ, in °C) is calculated from the ambient temperature (TA, in °C) and power dissipation (PD, in watts) according to the formula: TJ = TA + (PD • θJA), where θJA (in °C/W) is the package thermal impedance."
        },
        {
          "Note": "2",
          "Text": "The quiescent current in Discontinuous Mode does not include switching loss of the power FETs."
        },
        {
          "Note": "3",
          "Text": "VFB is measured in a feedback loop that servos VITH to a specified voltage."
        },
        {
          "Note": "4",
          "Text": "Inductor should be selected such that peak inductor current does not exceed 39A in application."
        }
      ],
      "docOrder": 4
    }
  ],
  "typicalPerformanceData": [
    {
      "figure": 2,
      "title": "Efficiency and Power Loss (1MHz)",
      "altText": "Efficiency and power loss versus load current for the LT7153SP at 1MHz switching frequency with PV_IN = SV_IN = 3.3V and VOUT = 0.5V, showing peak efficiency near 90% around 10-15A load.",
      "imageDescription": "The plot has a dual y-axis with efficiency (%) on the left axis ranging from approximately 70% to 100%, and power loss (W) on the right axis ranging from 0 to 3.0W. The x-axis shows load current from 0 to 25A. The red efficiency curve rises steeply from ~75% at low currents, peaks near 90% around 10-15A, then slightly declines toward 25A. The cyan/teal power loss curve rises monotonically from near 0W at no load to approximately 2.5W at 25A. Operating conditions are PV_IN = SV_IN = 3.3V, VOUT = 0.5V, fSW = 1MHz, L = 70nH (0.17mΩ).",
      "curveSummary": {
        "xAxis": {
          "label": "LOAD CURRENT",
          "unit": "A",
          "min": 0,
          "max": 25
        },
        "yAxes": [
          {
            "axisId": "y1",
            "label": "EFFICIENCY",
            "unit": "%",
            "min": 70,
            "max": 100
          },
          {
            "axisId": "y2",
            "label": "POWER LOSS",
            "unit": "W",
            "min": 0,
            "max": 3.0
          }
        ],
        "operatingConditions": [
          "PV_IN=3.3V",
          "SV_IN=3.3V",
          "VOUT=0.5V",
          "fSW=1MHz",
          "L=70nH (0.17mΩ)"
        ],
        "series": [
          {
            "name": "EFFICIENCY",
            "yAxisRef": "y1",
            "trend": "Rises steeply from ~75% at low load, peaks near 90% at approximately 12A, then gradually decreases toward 25A.",
            "keyValues": [
              {
                "x": 0.5,
                "y": 75,
                "note": "low load efficiency"
              },
              {
                "x": 12,
                "y": 90,
                "note": "approximate peak efficiency"
              },
              {
                "x": 25,
                "y": 87,
                "note": "full load efficiency"
              }
            ]
          },
          {
            "name": "POWER LOSS",
            "yAxisRef": "y2",
            "trend": "Increases monotonically from near zero at no load to approximately 2.5W at full 25A load.",
            "keyValues": [
