    {
      "figure": 13,
      "title": "Output Tracking",
      "altText": "Output tracking waveform showing VTRACK/SS (500mV/DIV) and VOUT (500mV/DIV) tracking behavior with VIN=3.3V, VOUT=0.5V, ROUT=0.1Ω, FSW=1MHz. VOUT tracks VTRACK/SS with a sinusoidal-like profile.",
      "imageDescription": "Two-channel oscilloscope plot with time axis at 1ms/DIV. Top channel (green) shows VTRACK/SS at 500mV/DIV scale displaying a triangular/sinusoidal rising and falling waveform. Bottom channel (yellow) shows VOUT at 500mV/DIV tracking the VTRACK/SS signal. The output follows the tracking reference smoothly, demonstrating the tracking functionality of the IC.",
      "curveSummary": {
        "xAxis": {
          "label": "Time",
          "unit": "ms/DIV",
          "min": 0,
          "max": 7
        },
        "yAxes": [
          {
            "axisId": "y1",
            "label": "VTRACK/SS",
            "unit": "mV/DIV",
            "min": 0,
            "max": 3500
          },
          {
            "axisId": "y2",
            "label": "VOUT",
            "unit": "mV/DIV",
            "min": 0,
            "max": 3500
          }
        ],
        "operatingConditions": [
          "VIN=3.3V",
          "VOUT=0.5V",
          "ROUT=0.1Ω",
          "FSW=1MHz",
          "L=70nH",
          "COUT=5x100µF",
          "RITH=2kΩ",
          "CITH=10nF"
        ],
        "series": [
          {
            "name": "VTRACK/SS",
            "yAxisRef": "y1",
            "trend": "Rises smoothly to a peak then falls back down in a triangular/sinusoidal shape.",
            "keyValues": [
              {
                "x": 3,
                "y": 3000,
                "note": "peak tracking voltage"
              }
            ]
          },
          {
            "name": "VOUT",
            "yAxisRef": "y2",
            "trend": "Follows VTRACK/SS closely, rising and falling in synchrony with the reference.",
            "keyValues": [
              {
                "x": 3,
                "y": 500,
                "note": "VOUT at peak, clamped to regulated value"
              }
            ]
          }
        ]
      },
      "docOrder": 10
    },
    {
      "figure": 14,
      "title": "Start-up Waveform",
      "altText": "Start-up waveform showing VRUN (3V/DIV), VPGOOD (3V/DIV), and VOUT (500mV/DIV) with VIN=3.3V, VOUT=0.5V, ROUT=0.1Ω, FSW=1MHz. VOUT ramps up smoothly after VRUN is asserted.",
      "imageDescription": "Three-channel oscilloscope plot with time axis at 50ms/DIV. Top channel (purple) shows VRUN at 3V/DIV stepping high to enable the converter. Middle channel (blue) shows VPGOOD at 3V/DIV asserting after VOUT reaches regulation. Bottom channel (yellow) shows VOUT at 500mV/DIV ramping up linearly from 0V to 0.5V. The soft-start ramp is controlled by CTRACK/SS=4.7µF.",
      "curveSummary": {
        "xAxis": {
          "label": "Time",
          "unit": "ms/DIV",
          "min": 0,
          "max": 350
        },
        "yAxes": [
          {
            "axisId": "y1",
            "label": "VRUN",
            "unit": "V/DIV",
            "min": 0,
            "max": 21
          },
          {
            "axisId": "y2",
            "label": "VPGOOD",
            "unit": "V/DIV",
            "min": 0,
            "max": 21
          }
        ],
        "operatingConditions": [
          "VIN=3.3V",
          "VOUT=0.5V",
          "ROUT=0.1Ω",
          "FSW=1MHz",
          "L=70nH",
          "COUT=5x100µF",
          "RITH=2kΩ",
          "CITH=10nF",
          "CTRACK/SS=4.7µF"
        ],
        "series": [
          {
            "name": "VRUN",
            "yAxisRef": "y1",
            "trend": "Steps from low to high at start-up, enabling the converter.",
            "keyValues": [
              {
                "x": 50,
                "y": 3,
                "note": "VRUN assertion"
              }
            ]
          },
          {
            "name": "VPGOOD",
            "yAxisRef": "y2",
            "trend": "Remains low during ramp, then asserts high after VOUT reaches regulation.",
            "keyValues": [
              {
                "x": 200,
                "y": 3,
                "note": "PGOOD assertion after regulation"
              }
            ]
          },
          {
            "name": "VOUT",
            "yAxisRef": "y2",
            "trend": "Ramps up linearly from 0V to 0.5V regulated output following soft-start.",
            "keyValues": [
              {
                "x": 200,
                "y": 500,
                "note": "VOUT reaches regulation"
              }
            ]
          }
        ]
      },
      "docOrder": 11
    },
    {
      "figure": 15,
      "title": "Start-up Waveform (with Prebiased Output)",
      "altText": "Start-up waveform with prebiased output showing VRUN (3V/DIV), VPGOOD (3V/DIV), and VOUT (500mV/DIV) with VIN=3.3V, VOUT=0.5V, FSW=1MHz. VOUT starts from a prebiased level and ramps to regulation without undershoot.",
      "imageDescription": "Three-channel oscilloscope plot with time axis at 50ms/DIV. Top channel (purple) shows VRUN at 3V/DIV stepping high to enable the converter. Middle channel (blue) shows VPGOOD at 3V/DIV asserting after VOUT reaches regulation. Bottom channel (yellow) shows VOUT at 500mV/DIV starting from a prebiased level and continuing to ramp up to 0.5V without discharging below the initial prebias level. The prebias start-up demonstrates the IC's ability to start into a prebiased load without disturbing the existing output voltage.",
      "curveSummary": {
        "xAxis": {
          "label": "Time",
          "unit": "ms/DIV",
          "min": 0,
          "max": 350
        },
        "yAxes": [
          {
            "axisId": "y1",
            "label": "VRUN",
            "unit": "V/DIV",
            "min": 0,
            "max": 21
          },
          {
            "axisId": "y2",
            "label": "VPGOOD",
            "unit": "V/DIV",
            "min": 0,
            "max": 21
          }
        ],
        "operatingConditions": [
          "VIN=3.3V",
          "VOUT=0.5V",
          "ROUT=0.1Ω",
          "FSW=1MHz",
          "L=70nH",
          "COUT=5x100µF",
          "RITH=2kΩ",
          "CITH=10nF",
          "CTRACK/SS=4.7µF"
        ],
        "series": [
          {
            "name": "VRUN",
            "yAxisRef": "y1",
            "trend": "Steps from low to high enabling the converter while output is prebiased.",
            "keyValues": [
              {
                "x": 50,
                "y": 3,
                "note": "VRUN assertion"
              }
            ]
          },
          {
            "name": "VPGOOD",
            "yAxisRef": "y2",
            "trend": "Remains low during ramp then asserts high after VOUT reaches final regulation.",
            "keyValues": [
              {
                "x": 200,
                "y": 3,
                "note": "PGOOD assertion"
              }
            ]
          },
          {
            "name": "VOUT",
            "yAxisRef": "y2",
            "trend": "Starts from a prebiased level above 0V and ramps up to 0.5V without undershoot.",
            "keyValues": [
              {
                "x": 50,
                "y": 200,
                "note": "prebias initial level"
              },
              {
                "x": 200,
                "y": 500,
                "note": "regulated output"
              }
            ]
          }
        ]
      },
      "docOrder": 12
    },
