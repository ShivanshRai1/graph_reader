    {
      "figure": 20,
      "title": "Regulated FB Voltage vs. Temperature",
      "altText": "Regulated FB voltage decreases slightly with temperature from ~501.8mV at -50°C to ~500.2mV at 125°C, showing good regulation stability.",
      "imageDescription": "X-axis is Temperature in °C ranging from -50 to 125. Y-axis is Regulated FB Voltage in mV ranging from 498 to 503. A single curve shows a mild negative slope starting at approximately 501.8mV at -50°C and declining to about 500.2mV at 125°C. The variation is less than 2mV over the full temperature range. No explicit conditions are annotated on the plot.",
      "curveSummary": {
        "xAxis": {
          "label": "Temperature",
          "unit": "°C",
          "min": -50,
          "max": 125
        },
        "yAxes": [
          {
            "axisId": "y1",
            "label": "Regulated FB Voltage",
            "unit": "mV",
            "min": 498,
            "max": 503
          }
