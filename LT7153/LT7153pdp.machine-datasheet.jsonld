    {
      "figure": 8,
      "title": "Discontinuous Mode (DCM) Operation",
      "altText": "Oscilloscope waveforms showing Discontinuous Conduction Mode (DCM) operation with VOUT AC-coupled ripple, switch node voltage VSW, and inductor current IL at VIN=3.3V, VOUT=0.5V, IOUT=0A, fSW=1MHz.",
      "imageDescription": "Time-domain oscilloscope capture with time axis at 100µs/DIV. Three waveform traces are shown: VOUT AC-coupled at 20mV/DIV showing small ripple, VSW at 2V/DIV showing switching pulses, and IL at 5A/DIV showing inductor current pulses that return to zero between switching events (confirming DCM). Conditions: VIN=3.3V, VOUT=0.5V, IOUT=0A, fSW=1MHz, L=70nH, COUT=5×100µF, RITH=2kΩ, CITH=10nF.",
      "docOrder": 5
    },
    {
      "figure": 9,
      "title": "Forced Continuous Mode (FCM) Operation",
      "altText": "Oscilloscope waveforms showing Forced Continuous Conduction Mode (FCM) operation with VOUT AC-coupled ripple, VCLKOUT, VSW, and IL at VIN=3.3V, VOUT=0.5V, IOUT=0A, fSW=1MHz.",
      "imageDescription": "Time-domain oscilloscope capture with time axis at 500ns/DIV. Four waveform traces are shown: VOUT AC-coupled at 5mV/DIV showing very small ripple, VCLKOUT at 5V/DIV showing a clock output signal, VSW at 5V/DIV showing switching pulses, and IL at 5A/DIV showing continuous triangular inductor current that goes negative (confirming FCM). Conditions: VIN=3.3V, VOUT=0.5V, IOUT=0A, fSW=1MHz, L=70nH, COUT=5×100µF, RITH=2kΩ, CITH=10nF.",
      "docOrder": 6
    },
    {
      "figure": 10,
      "datasetId": "fig-10-g10-g12-3-load-transient-waveforms-1-dcm-50ma-to-8a-comp-1k-10nf-load-transient-dcm-50ma-8a",
